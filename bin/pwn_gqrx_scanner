#!/usr/bin/env ruby
# frozen_string_literal: true

require 'pwn'

opts = PWN::Env[:driver_opts]
PWN::Driver::Parser.new do |options|
  options.on('-aPROFILE', '--assume-band-plan=PROFILE', '<Required if "--target-freq" is Nil - Band Plan Profile to assume for common radio protocols.  Use "--list-band-plans" to display supported protocols (Defaults to nil)') do |p|
    opts[:profile] = p
  end

  options.on('-l', '--list-band-plans', '<Optional - List supported band plan profiles and exit>') do |l|
    opts[:list_band_plans] = l
  end

  options.on('-sFREQS', '--scan-ranges=FREQS', '<Required if "--assume-band-plan" is Nil - Comma-Delimited List of Frequency Ranges to Scan (e.g. 800.000.000 == 800 mHz>') do |s|
    opts[:scan_ranges] = s
  end

  options.on('-hHOST', '--host=HOST', '<Optional - GQRX Host (Defaults to 127.0.0.1)>') do |h|
    opts[:host] = h
  end

  options.on('-pPORT', '--port=PORT', '<Optional - GQRX Port (Defaults to 7356)>') do |p|
    opts[:port] = p
  end

  options.on('-AFLOAT', '--audio-gain=FLOAT', '<Optional - Set audio gain -80.0 to 50.0 (Defaults to 9.0)>') do |a|
    opts[:audio_gain_db] = a
  end

  options.on('-bHZ', '--bandwidth=HZ', '<Optional - Set Bandwidth 0.0 - SDR Bandwidth Limit, e.g. 20.000.000 (Defaults to 270.000)>') do |b|
    opts[:bandwidth] = b
  end

  options.on('-DMODE', '--demodulator-mode=MODE', '<Optional - Set Demodulator Mode OFF | RAW | AM | FM | WFM | WFM_ST | WFM_ST_OIRT | LSB | USB | CW | CWL | CWU (Defaults to WFM_ST)>') do |d|
    opts[:demodulator_mode] = d
  end

  options.on('-PINT', '--precision=INT', '<Optional - Precision of Frequency 1-12 (Defaults to 5)>') do |p|
    opts[:precision] = p
  end

  options.on('-SFLOAT', '--strength-lock=FLOAT', '<Optional - Strength to lock onto frequency (Defaults to -70.0)>') do |s|
    opts[:strength_lock] = s
  end

  options.on('-QFLOAT', '--squelch=FLOAT', '<Optional - Squelch Threshold -150.0 to 0 (Defaults to --strength-lock - 3)>') do |q|
    opts[:squelch] = q
  end

  options.on('-RFLOAT', '--rf-gain=FLOAT', '<Optional - RF Gain 0.0-16.0(Defaults to 0.0)>') do |r|
    opts[:rf_gain] = r
  end

  options.on('-IFLOAT', '--intermediate-gain=FLOAT', '<Optional - Intermediate Gain 0.0-40.0 (Defaults to 32.0)>') do |i|
    opts[:intermediate_gain] = i
  end

  options.on('-BFLOAT', '--baseband-gain=FLOAT', '<Optional - Baseband Gain 0.0-62.0 (Defaults to 10.0)>') do |b|
    opts[:baseband_gain] = b
  end

  options.on('-k', '--keep-looping', '<Optional - Keep looping over the scan range indefinitely until CTRL+C is caught (Defaults to false)>') do |k|
    opts[:keep_looping] = k
  end

  options.on('-LFILE', '--scan-log=FILE', '<Optional - Path to log scan results to (Defaults to /tmp/pwn_sdr_gqrx_scan_<start_freq>-<target_freq>_<timestamp>.json)>') do |l|
    opts[:scan_log] = l
  end

  options.on('-wLOC', '--location=LOC', '<Optional - Location string to include in AI analysis (e.g. "New York, NY", 90210, GPS coords, etc.)>') do |l|
    opts[:location] = l
  end
  options.on('--fft-scan', '<Optional - Use fast FFT-based panoramic scanning via #fast_scan_range (much faster) instead of #scan_range. Applies to profile or --scan-ranges>') do |f|
    opts[:fft_scan] = f
  end

  options.on('--sample-rate=RATE', '<Optional --fft-scan - Visible span/sample_rate in Hz (default 1_000_000). NOTE: no short flag; -S is --strength-lock>') do |s|
    opts[:sample_rate] = s
  end

  options.on('-NINT', '--nfft=INT', '<Optional --fft-scan - FFT bin size (default 2048)>') do |n|
    opts[:nfft] = n
  end

  options.on('--avg=INT', '<Optional --fft-scan - FFT averages (default 8). NOTE: no short flag; -A is --audio-gain>') do |a|
    opts[:avg] = a
  end

  options.on('-CSEC', '--capture-secs=SEC', '<Optional --fft-scan - Capture seconds per chunk (default 0.10)>') do |c|
    opts[:capture_secs] = c
  end

  options.on('--keep-spectrum', '<Optional --fft-scan - Keep full spectrum data in output (large)>') do |k|
    opts[:keep_spectrum] = k
  end

  options.on('-ODB', '--strength-offset-db=FLOAT', '<Optional - Power offset in dB (default 0.0)>') do |o|
    opts[:strength_offset_db] = o
  end

  options.on('--min-snr-db=FLOAT', '<Optional --fft-scan - Minimum SNR (dB above per-chunk noise floor) to report a signal (default 12.0)>') do |m|
    opts[:min_snr_db] = m
  end

  options.on('--min-bw-ratio=FLOAT', '<Optional --fft-scan - Reject FFT peaks narrower than RATIO * band-plan bandwidth as spurs (default 0.30)>') do |r|
    opts[:min_bw_ratio] = r
  end

  options.on('--no-refine', '<Optional --fft-scan - Skip the post-FFT iterative edge/peak refine pass that locks the exact channel frequency (default: refine ON)>') do
    opts[:refine] = false
  end
end.parse!

begin
  pwn_provider = 'ruby-gem'
  pwn_provider = ENV.fetch('PWN_PROVIDER') if ENV.keys.any? { |s| s == 'PWN_PROVIDER' }

  band_plans = PWN::SDR::FrequencyAllocation.band_plans

  list_band_plans = opts[:list_band_plans]
  if list_band_plans
    puts JSON.pretty_generate(band_plans)
    exit 0
  end

  profile = opts[:profile]
  # Merge opts with profile values if profile provided
  opts.merge!(band_plans[profile.to_sym]) unless profile.nil?

  scan_ranges = opts[:scan_ranges]
  raise 'ERROR: --assume-band-plan || --scan-ranges is required.' if scan_ranges.nil? && profile.nil?

  ranges = band_plans[profile.to_sym][:ranges] unless profile.nil?
  if ranges.nil?
    # Convert comma-delimited string to array of hashes
    ranges = scan_ranges.split(',').map do |r|
      range = r.split('-')
      { start_freq: range.first, target_freq: range.last }
    end
  elsif scan_ranges
    # Append scan_ranges to profile ranges if both provided
    additional_ranges = scan_ranges.split(',').map do |r|
      range = r.split('-')
      { start_freq: range.first, target_freq: range.last }
    end
    ranges.concat(additional_ranges)
  end

  host = opts[:host]
  port = opts[:port]
  gqrx_sock = PWN::SDR::GQRX.connect(target: host, port: port)

  demodulator_mode = opts[:demodulator_mode]
  bandwidth = opts[:bandwidth]

  audio_gain_db = opts[:audio_gain_db]
  audio_gain_db = audio_gain_db.to_f unless audio_gain_db.nil?

  squelch = opts[:squelch]
  squelch = squelch.to_f unless squelch.nil?

  precision = opts[:precision] ||= 5
  precision = precision.to_i
  raise "ERROR: Invalid precision: #{precision}" unless (1..12).include?(precision)

  strength_lock = opts[:strength_lock]
  strength_lock = strength_lock.to_f unless strength_lock.nil?

  rf_gain = opts[:rf_gain]
  rf_gain = rf_gain.to_f unless rf_gain.nil?

  intermediate_gain = opts[:intermediate_gain]
  intermediate_gain = intermediate_gain.to_f unless intermediate_gain.nil?

  baseband_gain = opts[:baseband_gain]
  baseband_gain = baseband_gain.to_f unless baseband_gain.nil?

  keep_looping = opts[:keep_looping]
  scan_log = opts[:scan_log]
  decoder = opts[:decoder]
  location = opts[:location]

  # Merge opts one last time to ensure parameters passed to the driver are included
  opts.merge!(band_plans[profile.to_sym]) unless profile.nil?

  fft_scan = opts[:fft_scan]
  sample_rate = opts[:sample_rate] || 1_000_000
  sample_rate = sample_rate.to_i
  nfft = opts[:nfft] || 2048
  nfft = nfft.to_i
  avgv = opts[:avg] || 8
  avgv = avgv.to_i
  capture_secs = opts[:capture_secs] || 0.10
  capture_secs = capture_secs.to_f
  keep_spectrum = opts[:keep_spectrum] ? true : false
  strength_offset_db = opts[:strength_offset_db]
  strength_offset_db = strength_offset_db.to_f unless strength_offset_db.nil?
  min_snr_db = opts[:min_snr_db]
  min_snr_db = min_snr_db.to_f unless min_snr_db.nil?
  min_bw_ratio = opts[:min_bw_ratio]
  min_bw_ratio = min_bw_ratio.to_f unless min_bw_ratio.nil?

  if fft_scan
    puts '[*] --fft-scan requested: using fast FFT panoramic mode (#fast_scan_range)'
    refine_flag = opts.fetch(:refine, true)
    puts "[*] band-plan / session params: mode=#{demodulator_mode.inspect} bw=#{bandwidth.inspect} " \
         "squelch=#{squelch.inspect} precision=#{precision} decoder=#{decoder.inspect} " \
         "rf_gain=#{rf_gain.inspect} if_gain=#{intermediate_gain.inspect} bb_gain=#{baseband_gain.inspect} " \
         "refine=#{refine_flag}"
    fast_resp = PWN::SDR::GQRX.fast_scan_range(
      gqrx_sock: gqrx_sock,
      ranges: ranges,
      sample_rate: sample_rate,
      nfft: nfft,
      avg: avgv,
      capture_secs: capture_secs,
      strength_lock: strength_lock,
      keep_spectrum: keep_spectrum,
      strength_offset_db: strength_offset_db,
      min_snr_db: min_snr_db,
      precision: precision,
      min_bw_ratio: min_bw_ratio,
      refine: opts.fetch(:refine, true),
      demodulator_mode: demodulator_mode,
      bandwidth: bandwidth,
      squelch: squelch,
      audio_gain_db: audio_gain_db,
      rf_gain: rf_gain,
      intermediate_gain: intermediate_gain,
      baseband_gain: baseband_gain,
      decoder: decoder,
      location: location,
      scan_log: scan_log
    )
    puts "FFT Scan complete: #{fast_resp[:total]} signals found."
  else
    PWN::SDR::GQRX.scan_range(
      gqrx_sock: gqrx_sock,
      ranges: ranges,
      demodulator_mode: demodulator_mode,
      bandwidth: bandwidth,
      audio_gain_db: audio_gain_db,
      squelch: squelch,
      precision: precision,
      strength_lock: strength_lock,
      rf_gain: rf_gain,
      intermediate_gain: intermediate_gain,
      baseband_gain: baseband_gain,
      keep_looping: keep_looping,
      scan_log: scan_log,
      decoder: decoder,
      location: location
    )
    puts 'Scan Complete.'
  end
rescue StandardError => e
  raise e
rescue Interrupt
  puts "\nCTRL+C detected - goodbye."
ensure
  PWN::SDR::GQRX.disconnect(gqrx_sock: gqrx_sock) unless gqrx_sock.nil?
end
