#!/usr/bin/env ruby
# frozen_string_literal: true

require 'pwn'

# ----------------------------------------------------------------------
# Bare-word subcommand: `pwn setup [...]` → delegate to bin/pwn_setup so
# `gem install pwn && pwn setup` is the canonical two-step install path.
# Must be handled BEFORE OptionParser (which would reject `setup`).
# ----------------------------------------------------------------------
if ARGV.first == 'setup'
  ARGV.shift
  setup_bin = File.expand_path('pwn_setup', __dir__)
  setup_bin = Gem.bin_path('pwn', 'pwn_setup') unless File.file?(setup_bin)
  load setup_bin
  exit
end

opts = PWN::Env[:driver_opts]
pwn_driver = PWN::Driver::Parser.new do |options|
  options.on(
    '-APROMPT',
    '--ai=PROMPT',
    "<Optional - Headless one-shot pwn-ai request (no TUI). '-' reads PROMPT " \
    'from STDIN. Final answer goes to STDOUT, tool activity to STDERR. ' \
    'Useful for quick tasks or CI/CD jobs>'
  ) do |a|
    opts[:ai] = a
  end

  options.on(
    '-S[PROFILE]',
    '--setup[=PROFILE]',
    '<Optional - Post-install doctor / capability provisioner. With no ' \
    "PROFILE runs a read-only check; with PROFILE (#{PWN::Setup::PROFILES.keys.join('|')}) " \
    'installs OS deps for that capability set. Same as `pwn setup` / `pwn_setup`>'
  ) do |p|
    opts[:setup] = p || true
  end
end
pwn_driver.auto_opts_help = false
pwn_driver.parse!

begin
  pwn_pid = Process.pid

  if opts[:setup]
    # ------------------------------------------------------------------
    # `pwn --setup`            → PWN::Setup.check   (read-only doctor)
    # `pwn --setup=web`        → PWN::Setup.deps(profile: :web)
    # ------------------------------------------------------------------
    if opts[:setup] == true
      r = PWN::Setup.check
      exit(r[:ok] ? 0 : 1)
    else
      PWN::Setup.deps(profile: opts[:setup])
    end
  elsif opts[:ai]
    # ------------------------------------------------------------------
    # Headless pwn-ai: behave as if the user typed PROMPT at the pwn-ai
    # TUI, but non-interactively — a single agent-loop turn with native
    # tool-calling. STDOUT receives ONLY the final answer so it can be
    # captured/piped; live tool dispatches stream to STDERR for CI logs.
    #   $ pwn --ai 'What ports are listening on this host?'
    #   $ echo "$PROMPT" | pwn --ai -
    # ------------------------------------------------------------------
    prompt = opts[:ai].to_s
    prompt = $stdin.read if prompt == '-' || (prompt.strip.empty? && !$stdin.tty?)
    raise 'ERROR: --ai requires a non-empty PROMPT (or pipe one via STDIN with --ai -)' if prompt.to_s.strip.empty?

    sess = PWN::Sessions.create(
      title: "pwn --ai #{Time.now.strftime('%Y-%m-%d %H:%M')}",
      source: 'pwn-ai-headless'
    )

    on_tool = lambda do |name, args, result|
      preview = args.is_a?(String) ? args[0, 120] : args.inspect[0, 120]
      warn "[ pwn-ai → #{name} ] #{preview}"
      warn result.to_s[0, 700]
    end

    final = PWN::AI::Agent::Loop.run(
      request: prompt,
      session_id: sess[:id],
      enabled_toolsets: PWN::Env.dig(:ai, :agent, :toolsets),
      on_tool: on_tool
    )
    puts final
  else
    PWN::Plugins::REPL.start
  end
rescue StandardError => e
  raise e
ensure
  ps_list_arr = PWN::Plugins::PS.list

  kid_pids_arr = ps_list_arr.select { |ps_line| ps_line[3] == pwn_pid.to_s }
  # pp kid_pids_arr

  grandkid_pids_arr = []
  kid_pids_arr.each do |kid_pid|
    gk_arr = ps_list_arr.select { |ps_line| ps_line[3] == kid_pid[2] }
    gk_arr.each { |gk| grandkid_pids_arr.push(gk) }
  end
  # pp grandkid_pids_arr

  PWN::Plugins::PS.cleanup_pids(pids_arr: grandkid_pids_arr)
  PWN::Plugins::PS.cleanup_pids(pids_arr: kid_pids_arr)
end
